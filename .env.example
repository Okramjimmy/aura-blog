# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection details.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blog
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# ─── Authentication ───────────────────────────────────────────────────────────
# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# REQUIRED. The server will refuse to start if this is not set.
SECRET_KEY=generate_a_strong_random_secret_here

# Admin login credentials for the /admin panel.
# REQUIRED.
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_strong_admin_password_here

# ─── Third-party APIs ─────────────────────────────────────────────────────────
# GitHub personal access token (classic) with read:user + repo scope.
# Required for the contribution heatmap on /github. Optional — heatmap is
# silently hidden if not set.
GITHUB_TOKEN=ghp_your_github_token_here

# Google Gemini API key (used for AI-assisted features).
GEMINI_API_KEY=your_gemini_api_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
# Public URL of the deployed app. Used for self-referential links.
APP_URL=http://localhost:3000

# Set to true to disable Vite HMR (useful during automated edits).
# DISABLE_HMR=true
